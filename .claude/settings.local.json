{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(chmod +x:*)",
      "Bash(git remote:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(python -m skills.security_guardian --scan backend --format text)",
      "Bash([ -d .git ])",
      "Bash(cp hooks/pre-commit .git/hooks/)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  }
}
