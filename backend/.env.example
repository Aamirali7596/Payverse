# PayVerse Tax MVP - Phase 1

# Application
APP_NAME=PayVerse Tax MVP
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./payverse_tax_mvp.db

# HMRC Sandbox
HMRC_CLIENT_ID=your-hmrc-client-id
HMRC_CLIENT_SECRET=your-hmrc-client-secret
HMRC_SANDBOX_URL=https://test-api.service.hmrc.gov.uk
HMRC_REDIRECT_URI=http://localhost:8000/auth/hmrc/callback
HMRC_SCOPES=read:vat write:vat read:self-assessment write:self-assessment

# Ollama
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL_CA=llama3:8b
DEFAULT_MODEL_EXTRACTION=codellama:7b

# Encryption
ENCRYPTION_KEY=32-byte-base64-key

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
